rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is an admin
    // Admins are identified by their email in the admin_users collection
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Admin users collection
    match /admin_users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Only created via Firebase Console / CLI
    }
    
    // RSVPs - anyone can create, only admins can read all/update/delete
    match /rsvps/{rsvpId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Photos - anyone can view approved photos, authenticated users can upload,
    // only admins can approve/delete
    match /photos/{photoId} {
      // Anyone can read approved photos (for the public gallery)
      allow read: if resource.data.approved == true || isAdmin();
      // Authenticated users can create new photo entries (upload goes to Storage)
      allow create: if isAuthenticated();
      // Only admins can update (approve/reject) or delete
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Guest messages - anyone can create, only admins can read/delete
    match /guest_messages/{messageId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
