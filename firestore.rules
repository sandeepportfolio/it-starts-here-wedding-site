rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // RSVPs — anyone can submit, admin portal can read/update/delete
    match /rsvps/{rsvpId} {
      allow read, write: if true;
    }

    // Photos — anyone can submit, admin portal can approve/reject/delete
    match /photos/{photoId} {
      allow read, write: if true;
    }

    // Messages — anyone can submit, admin portal can read/delete
    match /messages/{messageId} {
      allow read, write: if true;
    }

    // Admins collection — no longer used
    match /admins/{userId} {
      allow read, write: if false;
    }
  }
}
